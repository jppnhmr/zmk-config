#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/ext_power.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
// ------------------------------------------------------------------------------------------------------------
// |  ESC  |  1  |  2  |  3   |  4   |  5   |                   |  6   |  7    |  8    |  9   |   0   |   =   |
// |  TAB  |  Q  |  W  |  E   |  R   |  T   |                   |  Y   |  U    |  I    |  O   |   P   |   -   |
// | ENTER |  A  |  S  |  D   |  F   |  G   |                   |  H   |  J    |  K    |  L   |   ;   | ENTER |
// | SHIFT |  Z  |  X  |  C   |  V   |  B   |   "["  |  |  "]"  |  N   |  M    |  ,    |  .   |   /   | SHIFT |
//                     | CTRL | ALT  |LOWER |  SPACE |  | SPACE | RAISE| BSPC  | GUI   |
            bindings = <
&kp ESC   &kp N1 &kp N2 &kp N3   &kp N4   &kp N5                     &kp N6 &kp N7   &kp N8    &kp N9  &kp N0   &kp EQUAL
&kp TAB   &kp Q  &kp W  &kp E    &kp R    &kp T                      &kp Y  &kp U    &kp I     &kp O   &kp P    &kp MINUS
&kp ENTER &kp A  &kp S  &kp D    &kp F    &kp G                      &kp H  &kp J    &kp K     &kp L   &kp SEMI &kp ENTER
&kp LSHFT &kp Z  &kp X  &kp C    &kp V    &kp B  &kp LBKT   &kp RBKT &kp N  &kp M    &kp COMMA &kp DOT &kp FSLH &kp RSHFT
                        &kp LCTRL &kp LALT &mo 1 &kp SPACE  &kp SPACE  &mo 2  &kp BSPC &kp RGUI
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        lower_layer {
// ------------------------------------------------------------------------------------------------------------
// |  ~    |     |     |      |      | HOME |                   | HOME | PREV  |PauPly | NEXT | MUTE  | VOL UP|
// |  `    |     |     |  UP  |      | PGUP |                   | PGUP |       |  UP   |      |       | VOL DN|
// |       |     |LEFT | DOWN | RIGHT| PGDN |                   | PGDN | LEFT  | DOWN  | RIGHT|       |       |
// |  CAPS | "[" | "]" |   {  |  }   |  END |        |  |       |  END |   |   |  ;    |  :   |   \   | CAPS  |
//                     |      |      |      |        |  |       |      |       |       |
            bindings = <
&kp TILDE  &trans           &trans            &trans            &trans       &kp HOME                     &kp HOME   &kp K_PREV &kp K_PP   &kp K_NEXT &kp K_MUTE &kp K_VOL_UP
&kp GRAVE  &trans           &trans            &kp UP            &trans       &kp PG_UP                    &kp PG_UP  &trans     &kp UP     &trans     &trans     &kp K_VOL_DN
&trans     &trans           &kp LEFT          &kp DOWN          &kp RIGHT    &kp PG_DN                    &kp PG_DN  &kp LEFT   &kp DOWN   &kp RIGHT  &trans     &trans
&kp CAPS   &kp LBKT         &kp LBKT          &kp LBRC          &kp RBRC     &kp END   &trans   &trans    &kp END    &kp MINUS  &kp SEMI   &kp COLON  &kp BLSH   &kp CAPS
                                              &trans            &trans       &trans    &trans   &trans    &trans     &trans     &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };

        raise_layer {
// ------------------------------------------------------------------------------------------------------------
// | BT_SEL0  |  F1 |  F2 |  F3  |  F4  |  F5  |                   |      |   7   |   8   |  9   |   +   |       |
// | BT_SEL1  |  F6 |  F7 |  F8  |  F9  |  F10 |                   |      |   4   |   5   |  6   |   -   |       |
// | BT_SEL2  |  F11|  F12|  F13 |  F14 |  F15 |                   |      |   1   |   2   |  3   |   *   |       |
// | BT_CLR   |     |     |      |      | PSCRN|        |  |       |      |       |   0   |      |   /   |       |
//                     |      |      |      |        |  |       |      |       |       |
            bindings = <
&bt BT_SEL0   &kp F1  &kp F2  &kp F3   &kp F4   &kp F5                        &trans      &kp N7    &kp N8    &kp N9   &kp PLUS      &trans
&bt BT_SEL1   &kp F6  &kp F7  &kp F8   &kp F9   &kp F10                       &trans      &kp N4    &kp N5    &kp N6   &kp MIUNS     &trans
&bt BT_SEL2   &kp F11 &kp F12 &kp F13  &kp F14  &kp F15                       &trans      &kp N1    &kp N2    &kp N3   &kp ASTERISK  &trans
&bt BT_CLR    &trans  &trans  &trans   &trans   &trans     &trans   &trans    &trans      &trans    &kp N0    &trans   &kp FLSH      &trans
                          &trans   &trans   &trans     &trans   &trans    &trans      &trans    &trans
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };
    };
};
